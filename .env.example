###############################################################################
# OpenClaw Stack – Environment Variables
# =============================================================================
# Add these variables to Dokploy → Project → Environment
# Or copy as .env for local use: cp .env.example .env
###############################################################################

# ── GATEWAY ──────────────────────────────────────────────────────────────────
# Auto-generated after onboarding, or leave blank for auto-init
OPENCLAW_GATEWAY_TOKEN=

# Port (change if conflicts with another service)
OPENCLAW_GATEWAY_PORT=18789

# Gateway network bind mode (passed to `openclaw gateway --bind <value>`)
# Controls which network interface the gateway *process* listens on inside the container.
# Valid values: "lan", "loopback", "tailnet", "auto", "custom"
#   "lan" (default)      — Bind to 0.0.0.0 inside the container. Required for Docker
#                          port mapping to work. Host-level access control is handled
#                          by OPENCLAW_LISTEN_HOST below.
#   "loopback"           — Only accept connections from 127.0.0.1 inside the container.
#                          ⚠️  Docker port mapping will NOT work with this mode because
#                          traffic from Docker's proxy is not from 127.0.0.1.
#                          Only useful for sidecar containers in the same network namespace.
#   "tailnet"            — Bind to Tailscale interface
#   "auto"               — Auto-detect the best interface
# NOTE: This is different from OPENCLAW_LISTEN_HOST (Docker-level port binding, see below).
OPENCLAW_GATEWAY_BIND=lan

# Docker listen host for port mapping
# Controls which host network interface Docker exposes the ports on.
#   "127.0.0.1" (default) — Local access only (most secure)
#   "0.0.0.0"             — Accessible from all network interfaces (public)
# ⚠️  If set to 0.0.0.0, also set OPENCLAW_GATEWAY_BIND=lan so the gateway
#     process inside the container actually accepts external connections.
# ⚠️  For production, always place behind a reverse proxy with TLS.
OPENCLAW_LISTEN_HOST=127.0.0.1

# Public domain (enables auto-config CORS for Control UI)
# Example: https://openclaw.example.com
OPENCLAW_PUBLIC_URL=

# Timezone
TZ=Asia/Ho_Chi_Minh

# ── PROVIDER API KEYS (optional – leave blank if using custom provider only) ─
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# OPENROUTER_API_KEY=

# ── CUSTOM CHAT PROVIDER (OpenAI-compatible) ────────────────────────────────────
# For any OpenAI-compatible chat/completions provider: Together, Groq, LM Studio, etc.
# Auto-configured on container start (updated on every restart)
OCS_CHAT_BASE_URL=
OCS_CHAT_API_KEY=
OCS_CHAT_MODEL_ID=
OCS_CHAT_PROVIDER_NAME=chat
# Set to true if the model supports vision/images (e.g. gpt-4o, gemini-2.0-flash)
OCS_CHAT_SUPPORTS_IMAGES=false
# Context window (max input tokens)
OCS_CHAT_CONTEXT_WINDOW=200000
# Max output tokens
OCS_CHAT_MAX_TOKENS=8192

# ── CUSTOM EMBEDDING PROVIDER (OpenAI-compatible, for memory search) ──────────
# For dedicated embedding endpoints: OpenAI, local model server, etc.
# If blank, OpenClaw auto-detects from OPENAI_API_KEY / GOOGLE_AI_API_KEY.
# OCS_EMBED_API_KEY defaults to OCS_CHAT_API_KEY if left blank (same provider).
OCS_EMBED_BASE_URL=
OCS_EMBED_API_KEY=
OCS_EMBED_MODEL_ID=

# ── TELEGRAM ────────────────────────────────────────────────────────────────
# Bot token from @BotFather – auto-adds channel on container start
TELEGRAM_BOT_TOKEN=

# ── RESOURCE LIMITS ─────────────────────────────────────────────────────────
# Container memory limits
# OPENCLAW_MEM_LIMIT=4G
# OPENCLAW_MEM_RESERVATION=2G
# CHROMIUM_MEM_LIMIT=2G
# CHROMIUM_MEM_RESERVATION=512M
